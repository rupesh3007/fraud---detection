{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "framework": "vite",
  "env": {
    "VITE_API_URL": {
      "required": false,
      "description": "Backend API base URL (default: /api for proxy)"
    }
  },
  "rewrites": [
    {
      "source": "/:path((?!_next/.*|.*\\..*)*)",
      "destination": "/index.html"
    }
  ]
}
